{
  "buildCommand": "bun run build",
  "installCommand": "bun install",
  "framework": "nextjs",
  "functions": {
    "app/**/*.ts": {
      "includeFiles": "**"
    }
  },
  "redirects": [
    {
      "source": "/:path*",
      "destination": "https://nicolasmenard.design/:path*",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "www.nicolasmenard.design"
        }
      ]
    },
    {
      "source": "/work/factory-design-system",
      "destination": "/work/keeping-figma-and-react-in-sync",
      "permanent": true
    }
  ]
}